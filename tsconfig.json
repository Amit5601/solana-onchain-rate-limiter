{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["mocha", "node"],
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["tests/**/*.ts", "client/**/*.ts"]
}
